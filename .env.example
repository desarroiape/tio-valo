# Copia este archivo como .env.local y rellena tus valores.
# NO subas .env.local a GitHub (ya está en .gitignore).
# En Vercel, agrega estas mismas variables en Settings → Environment Variables.

# --- Telegram (formulario de vender) ---
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_CHAT_ID=123456789

# --- Supabase (catálogo + imágenes) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Panel /admin ---
ADMIN_PASSWORD=una-clave-fuerte
SESSION_SECRET=cadena-aleatoria-larga

# --- Discord (anuncio al publicar) ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# --- URL pública del sitio (enlace del anuncio de Discord) ---
SITE_URL=https://www.trustifymarket.online
